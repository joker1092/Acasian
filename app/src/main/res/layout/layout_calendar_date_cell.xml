<?xml version="1.0" encoding="utf-8"?>
<!--
    날짜 셀: 숫자 + 예약 뱃지 (시간 + 유형명)
    dot_1/dot_2: TextView 뱃지 (HH:mm 유형명)
    dot_3: +N 더보기 TextView
    minHeight 88dp — 뱃지 2개 공간 확보
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:paddingTop="5dp"
    android:paddingBottom="5dp"
    android:paddingStart="2dp"
    android:paddingEnd="2dp"
    android:minHeight="88dp">

    <!-- 날짜 숫자 -->
    <TextView
        android:id="@+id/txt_day"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="?attr/cal_cell_min_size"
        android:minHeight="?attr/cal_cell_min_size"
        android:gravity="center"/>

    <!-- 뱃지 컨테이너 -->
    <LinearLayout
        android:id="@+id/dot_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="3dp"
        android:visibility="gone">

        <!-- 뱃지 1 -->
        <TextView
            android:id="@+id/dot_1"
            android:layout_width="match_parent"
            android:layout_height="15dp"
            android:paddingStart="3dp"
            android:paddingEnd="2dp"
            android:textSize="8sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:layout_marginBottom="2dp"
            android:visibility="gone"/>

        <!-- 뱃지 2 -->
        <TextView
            android:id="@+id/dot_2"
            android:layout_width="match_parent"
            android:layout_height="15dp"
            android:paddingStart="3dp"
            android:paddingEnd="2dp"
            android:textSize="8sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:layout_marginBottom="2dp"
            android:visibility="gone"/>

        <!-- +N 더보기 -->
        <TextView
            android:id="@+id/dot_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="8sp"
            android:textStyle="bold"
            android:paddingStart="2dp"
            android:visibility="gone"/>

    </LinearLayout>

    <!-- 호환성 유지 -->
    <TextView
        android:id="@+id/txt_event_1"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"/>
    <TextView
        android:id="@+id/txt_event_2"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"/>
    <View
        android:id="@+id/view_dot"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"/>

</LinearLayout>
