<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/cream">

    <!-- ── 헤더 고정 ────────────────────────────────────────── -->
    <FrameLayout
        android:id="@+id/settingsHeaderFrame"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/gradient_forest_header">

            <View
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_gravity="bottom"
                android:background="@drawable/curve_bottom_cream"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingEnd="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="40dp">

                <!-- 홈 아이콘 + 타이틀 행 — 다른 화면(관수작업 등)과 동일한 패턴 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <ImageView
                        android:id="@+id/btnSettingsHome"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_nav_home"
                        android:tint="@color/white"
                        android:padding="10dp"
                        android:contentDescription="홈으로"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="설정"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="계정 및 시스템 설정"
                    android:textSize="13sp"
                    android:textColor="@color/mist"
                    android:layout_marginStart="48dp"/>
            </LinearLayout>
    </FrameLayout>

    <!-- ── 콘텐츠 (스크롤 가능) ──────────────────────────────── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/cream">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="32dp">

            <!-- ══ 계정 정보 카드 ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_white_card"
                android:padding="16dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="계정 정보"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_hint"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <FrameLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_avatar"
                        android:layout_marginEnd="14dp">
                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_user"
                            android:contentDescription="계정"/>
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="전화번호"
                            android:textSize="11sp"
                            android:textColor="@color/text_hint"
                            android:layout_marginBottom="2dp"/>

                        <TextView
                            android:id="@+id/tvSettingsPhone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ══ 유형 관리 카드 ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_white_card"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="유형 관리"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_hint"
                    android:letterSpacing="0.08"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="4dp"/>

                <!-- 관수 유형 변경 → IrrigationTypeManagerFragment overlay -->
                <LinearLayout
                    android:id="@+id/menuIrrigationType"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_pump"
                        android:layout_marginEnd="12dp"
                        android:contentDescription="@null"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="관수 유형 관리"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textSize="20sp"
                        android:textColor="@color/text_hint"/>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"/>

                <!-- 환경기준 등록 -->
                <LinearLayout
                    android:id="@+id/menuEnvStandard"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_sensor"
                        android:layout_marginEnd="12dp"
                        android:contentDescription="@null"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="환경기준 등록"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:id="@+id/icEnvArrow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textSize="20sp"
                        android:textColor="@color/text_hint"/>
                </LinearLayout>

                <!-- 환경기준 패널 -->
                <LinearLayout
                    android:id="@+id/panelEnvStandard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="16dp"
                    android:background="@color/morning"
                    android:visibility="gone">

                    <!-- 지습 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="지습 관리범위 (%)"
                        android:textSize="12sp"
                        android:textColor="@color/text_hint"
                        android:layout_marginBottom="6dp"
                        android:layout_marginTop="4dp"/>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">
                        <android.widget.EditText
                            android:id="@+id/etSoilMin"
                            android:layout_width="0dp"
                            android:layout_height="@dimen/input_height"
                            android:layout_weight="1"
                            android:hint="최소"
                            android:inputType="numberDecimal"
                            android:textSize="15sp"
                            android:background="@drawable/bg_input_normal"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:layout_marginEnd="8dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="~"
                            android:textSize="16sp"
                            android:textColor="@color/text_hint"
                            android:layout_marginEnd="8dp"/>
                        <android.widget.EditText
                            android:id="@+id/etSoilMax"
                            android:layout_width="0dp"
                            android:layout_height="@dimen/input_height"
                            android:layout_weight="1"
                            android:hint="최대"
                            android:inputType="numberDecimal"
                            android:textSize="15sp"
                            android:background="@drawable/bg_input_normal"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"/>
                    </LinearLayout>

                    <!-- 지온 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="지온 상한 (°C)"
                        android:textSize="12sp"
                        android:textColor="@color/text_hint"
                        android:layout_marginBottom="6dp"/>
                    <android.widget.EditText
                        android:id="@+id/etTempMax"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:hint="예: 45"
                        android:inputType="numberDecimal"
                        android:textSize="15sp"
                        android:background="@drawable/bg_input_normal"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:layout_marginBottom="10dp"/>

                    <!-- EC -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="EC 관리범위 (dS/m)"
                        android:textSize="12sp"
                        android:textColor="@color/text_hint"
                        android:layout_marginBottom="6dp"/>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">
                        <android.widget.EditText
                            android:id="@+id/etEcMin"
                            android:layout_width="0dp"
                            android:layout_height="@dimen/input_height"
                            android:layout_weight="1"
                            android:hint="최소"
                            android:inputType="numberDecimal"
                            android:textSize="15sp"
                            android:background="@drawable/bg_input_normal"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:layout_marginEnd="8dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="~"
                            android:textSize="16sp"
                            android:textColor="@color/text_hint"
                            android:layout_marginEnd="8dp"/>
                        <android.widget.EditText
                            android:id="@+id/etEcMax"
                            android:layout_width="0dp"
                            android:layout_height="@dimen/input_height"
                            android:layout_weight="1"
                            android:hint="최대"
                            android:inputType="numberDecimal"
                            android:textSize="15sp"
                            android:background="@drawable/bg_input_normal"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"/>
                    </LinearLayout>

                    <!-- pH -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="pH 관리범위"
                        android:textSize="12sp"
                        android:textColor="@color/text_hint"
                        android:layout_marginBottom="6dp"/>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">
                        <android.widget.EditText
                            android:id="@+id/etPhMin"
                            android:layout_width="0dp"
                            android:layout_height="@dimen/input_height"
                            android:layout_weight="1"
                            android:hint="최소"
                            android:inputType="numberDecimal"
                            android:textSize="15sp"
                            android:background="@drawable/bg_input_normal"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:layout_marginEnd="8dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="~"
                            android:textSize="16sp"
                            android:textColor="@color/text_hint"
                            android:layout_marginEnd="8dp"/>
                        <android.widget.EditText
                            android:id="@+id/etPhMax"
                            android:layout_width="0dp"
                            android:layout_height="@dimen/input_height"
                            android:layout_weight="1"
                            android:hint="최대"
                            android:inputType="numberDecimal"
                            android:textSize="15sp"
                            android:background="@drawable/bg_input_normal"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"/>
                    </LinearLayout>

                    <!-- 저장 버튼 -->
                    <TextView
                        android:id="@+id/btnSaveEnv"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/button_height"
                        android:gravity="center"
                        android:text="저장"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:background="@drawable/bg_login_button"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="8dp"/>
            </LinearLayout>

            <!-- ══ 설치 장비 정보 카드 ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_white_card"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="설치 장비 정보"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_hint"
                    android:letterSpacing="0.08"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="4dp"/>

                <!-- 물탱크 설치 여부 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="물탱크 설치"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="수원 방식 (탱크 / 직수)"
                            android:textSize="12sp"
                            android:textColor="@color/text_hint"/>
                    </LinearLayout>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchTank"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp"
                    android:background="@color/divider" android:layout_marginStart="16dp" android:layout_marginEnd="16dp"/>

                <!-- 수위 센서 설치 여부 -->
                <LinearLayout
                    android:id="@+id/rowSensorSwitch"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:alpha="0.4">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="수위 센서 설치"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="탱크 수위 감지 여부"
                            android:textSize="12sp"
                            android:textColor="@color/text_hint"/>
                    </LinearLayout>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchSensor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false"
                        android:enabled="false"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp"
                    android:background="@color/divider" android:layout_marginStart="16dp" android:layout_marginEnd="16dp"/>

                <!-- 펌프 마력수 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="펌프 마력수"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="정격 출력 기준 (HP)"
                            android:textSize="12sp"
                            android:textColor="@color/text_hint"/>
                    </LinearLayout>
                    <EditText
                        android:id="@+id/etPumpHp"
                        android:layout_width="80dp"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:hint="2.0"
                        android:inputType="numberDecimal"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"
                        android:background="@drawable/bg_input_normal"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" HP"
                        android:textSize="14sp"
                        android:textColor="@color/text_hint"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp"
                    android:background="@color/divider" android:layout_marginStart="16dp" android:layout_marginEnd="16dp"/>

                <!-- 주관 직경 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="주관 직경"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="메인 공급관 내경"
                            android:textSize="12sp"
                            android:textColor="@color/text_hint"/>
                    </LinearLayout>
                    <EditText
                        android:id="@+id/etMainPipe"
                        android:layout_width="80dp"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:hint="50"
                        android:inputType="number"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"
                        android:background="@drawable/bg_input_normal"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" mm"
                        android:textSize="14sp"
                        android:textColor="@color/text_hint"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp"
                    android:background="@color/divider" android:layout_marginStart="16dp" android:layout_marginEnd="16dp"/>

                <!-- 토출관 직경 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="토출관 직경"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="밸브 출구관 내경"
                            android:textSize="12sp"
                            android:textColor="@color/text_hint"/>
                    </LinearLayout>
                    <EditText
                        android:id="@+id/etOutPipe"
                        android:layout_width="80dp"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:hint="25"
                        android:inputType="number"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"
                        android:background="@drawable/bg_input_normal"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" mm"
                        android:textSize="14sp"
                        android:textColor="@color/text_hint"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>

                <!-- 저장 버튼 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/btnEquipSave"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="14dp"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/morning">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="저장"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/forest_dark"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- ══ 계정 관리 카드 ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_white_card"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="계정 관리"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_hint"
                    android:letterSpacing="0.08"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="4dp"/>

                <!-- 정보변경 (비밀번호) -->
                <LinearLayout
                    android:id="@+id/menuInfoChange"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_lock"
                        android:layout_marginEnd="12dp"
                        android:contentDescription="@null"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="비밀번호 변경"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"/>

                    <ImageView
                        android:id="@+id/icInfoChangeArrow"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@android:drawable/arrow_down_float"
                        android:alpha="0.4"/>
                </LinearLayout>

                <!-- 비밀번호 변경 패널 -->
                <LinearLayout
                    android:id="@+id/panelInfoChange"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="16dp"
                    android:background="@color/morning"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="현재 비밀번호"
                        android:textSize="12sp"
                        android:textColor="@color/text_hint"
                        android:layout_marginBottom="6dp"
                        android:layout_marginTop="10dp"/>

                    <LinearLayout
                        android:id="@+id/containerCurrentPw"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_input_normal"
                        android:paddingStart="14dp"
                        android:paddingEnd="10dp"
                        android:layout_marginBottom="10dp">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_lock"
                            android:layout_marginEnd="10dp"
                            android:contentDescription="@null"/>
                        <EditText
                            android:id="@+id/etCurrentPw"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:hint="현재 비밀번호"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_hint"
                            android:background="@null"
                            android:inputType="textPassword"
                            android:imeOptions="actionNext"/>
                        <ImageView
                            android:id="@+id/btnToggleCurrent"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_eye_off"
                            android:padding="4dp"
                            android:contentDescription="@null"
                            android:background="?attr/selectableItemBackgroundBorderless"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="새 비밀번호"
                        android:textSize="12sp"
                        android:textColor="@color/text_hint"
                        android:layout_marginBottom="6dp"/>

                    <LinearLayout
                        android:id="@+id/containerNewPw"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_input_normal"
                        android:paddingStart="14dp"
                        android:paddingEnd="10dp"
                        android:layout_marginBottom="10dp">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_lock"
                            android:layout_marginEnd="10dp"
                            android:contentDescription="@null"/>
                        <EditText
                            android:id="@+id/etNewPw"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:hint="새 비밀번호 (4자리 이상)"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_hint"
                            android:background="@null"
                            android:inputType="textPassword"
                            android:imeOptions="actionNext"/>
                        <ImageView
                            android:id="@+id/btnToggleNew"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_eye_off"
                            android:padding="4dp"
                            android:contentDescription="@null"
                            android:background="?attr/selectableItemBackgroundBorderless"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="새 비밀번호 확인"
                        android:textSize="12sp"
                        android:textColor="@color/text_hint"
                        android:layout_marginBottom="6dp"/>

                    <LinearLayout
                        android:id="@+id/containerConfirmPw"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_input_normal"
                        android:paddingStart="14dp"
                        android:paddingEnd="10dp"
                        android:layout_marginBottom="14dp">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_lock"
                            android:layout_marginEnd="10dp"
                            android:contentDescription="@null"/>
                        <EditText
                            android:id="@+id/etConfirmPw"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:hint="새 비밀번호 재입력"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_hint"
                            android:background="@null"
                            android:inputType="textPassword"
                            android:imeOptions="actionDone"/>
                        <ImageView
                            android:id="@+id/btnToggleConfirm"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_eye_off"
                            android:padding="4dp"
                            android:contentDescription="@null"
                            android:background="?attr/selectableItemBackgroundBorderless"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/btnChangePassword"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/button_height"
                        android:gravity="center"
                        android:text="비밀번호 변경"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:background="@drawable/bg_login_button"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="8dp"/>
            </LinearLayout>

            <!-- ══ 로그아웃 ══ -->
            <TextView
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:gravity="center"
                android:text="로그아웃"
                android:textSize="15sp"
                android:textColor="#E53935"
                android:background="@drawable/bg_white_card"
                android:clickable="true"
                android:focusable="true"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
