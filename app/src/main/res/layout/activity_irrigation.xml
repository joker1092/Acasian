<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/light_gray">

    <!-- 헤더 -->
    <FrameLayout
        android:id="@+id/irrigHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/gradient_forest_header">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="20dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">
            <ImageView
                android:id="@+id/btnIrrigBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_nav_home"
                android:tint="@color/white"
                android:padding="10dp"
                android:contentDescription="뒤로"/>
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="관수작업"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingStart="4dp"/>
        </LinearLayout>
    </FrameLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingBottom="100dp">

            <!-- 게이트웨이 + 전체 제어 카드 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/card_bg">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <!-- GW 이름 + 변경 버튼 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="선택된 게이트웨이"
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp"/>
                            <TextView
                                android:id="@+id/tvIrrigGwName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="컨트롤박스 #1"
                                android:textColor="@color/text_primary"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>
                        <TextView
                            android:id="@+id/btnIrrigGwSelect"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="변경"
                            android:textColor="@color/white"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_header_btn"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:paddingTop="8dp"
                            android:paddingBottom="8dp"/>
                    </LinearLayout>

                    <!-- 구분선 -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginBottom="12dp"/>

                    <!-- 전체 제어 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- 상태 레이블 -->
                        <TextView
                            android:id="@+id/tvIrrigAllStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="대기 중"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp"
                            android:layout_marginBottom="8dp"/>

                        <!-- 버튼 행 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <!-- 전체 시작 (대기 상태) -->
                            <androidx.cardview.widget.CardView
                                android:id="@+id/btnIrrigAllStart"
                                android:layout_width="0dp"
                                android:layout_height="56dp"
                                android:layout_weight="1"
                                android:layout_marginEnd="6dp"
                                app:cardCornerRadius="10dp"
                                app:cardElevation="2dp"
                                app:cardBackgroundColor="@color/morning">
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:gravity="center">
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="▶  전체 시작"
                                        android:textColor="@color/forest_dark"
                                        android:textSize="15sp"
                                        android:textStyle="bold"/>
                                </LinearLayout>
                            </androidx.cardview.widget.CardView>

                            <!-- 전체 일시정지 (관수중 상태) -->
                            <androidx.cardview.widget.CardView
                                android:id="@+id/btnIrrigAllPause"
                                android:layout_width="0dp"
                                android:layout_height="56dp"
                                android:layout_weight="1"
                                android:layout_marginEnd="6dp"
                                android:visibility="gone"
                                app:cardCornerRadius="10dp"
                                app:cardElevation="2dp"
                                app:cardBackgroundColor="#FFF3E0">
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:gravity="center">
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="⏸  일시정지"
                                        android:textColor="#854F0B"
                                        android:textSize="15sp"
                                        android:textStyle="bold"/>
                                </LinearLayout>
                            </androidx.cardview.widget.CardView>

                            <!-- 전체 재개 (일시정지 상태) -->
                            <androidx.cardview.widget.CardView
                                android:id="@+id/btnIrrigAllResume"
                                android:layout_width="0dp"
                                android:layout_height="56dp"
                                android:layout_weight="1"
                                android:layout_marginEnd="6dp"
                                android:visibility="gone"
                                app:cardCornerRadius="10dp"
                                app:cardElevation="2dp"
                                app:cardBackgroundColor="@color/morning">
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:gravity="center">
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="▶  전체 재개"
                                        android:textColor="@color/forest_dark"
                                        android:textSize="15sp"
                                        android:textStyle="bold"/>
                                </LinearLayout>
                            </androidx.cardview.widget.CardView>

                            <!-- 전체 중지 (관수중 or 일시정지 상태) -->
                            <androidx.cardview.widget.CardView
                                android:id="@+id/btnIrrigAllStop"
                                android:layout_width="0dp"
                                android:layout_height="56dp"
                                android:layout_weight="1"
                                android:visibility="gone"
                                app:cardCornerRadius="10dp"
                                app:cardElevation="2dp"
                                app:cardBackgroundColor="@color/inactive_bg">
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:gravity="center">
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="■  전체 중지"
                                        android:textColor="@color/text_primary"
                                        android:textSize="15sp"
                                        android:textStyle="bold"/>
                                </LinearLayout>
                            </androidx.cardview.widget.CardView>

                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 관수 진행 상태 배너 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/irrigProgressSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/device_bg_running">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp">
                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/dot_shape"/>
                    <TextView
                        android:id="@+id/tvIrrigRunningStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="관수 진행 중"
                        android:textColor="@color/device_accent_running"
                        android:textSize="16sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 토출 밸브 목록 카드 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/card_bg">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="14dp"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="토출 밸브 목록"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:id="@+id/irrigValveContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- 하단 고정: 긴급 중지만 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingBottom="24dp"
        android:background="@color/card_bg"
        android:elevation="8dp">

        <androidx.cardview.widget.CardView
            android:id="@+id/btnIrrigEmergency"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/inactive_bg">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="■  긴급 중지"
                    android:textColor="@color/device_accent_error"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</LinearLayout>