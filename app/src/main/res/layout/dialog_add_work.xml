<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/add_scroll"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/forest_mid"
    android:padding="20dp">

    <!-- 타이틀 -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="작업 예약" android:textColor="@color/white"
        android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="16dp" />
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/moss" android:layout_marginBottom="12dp" />

    <!-- ══ 반복 / 단건 토글 (상단·소형) ══
         왼쪽=매주 반복(ON), 오른쪽=단건(OFF)
         호환성: 동일한 SwitchMaterial(@id/switchRepeat)을 invisible 상태로 유지 →
                 기존 DateDetailView 코드의 isChecked()/setOnCheckedChangeListener 그대로 동작 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="14dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="반복"
            android:textSize="13sp"
            android:textColor="@color/mist" />

        <!-- 세그먼트 토글: [매주 반복] [단건] — 36dp 높이 -->
        <LinearLayout
            android:layout_width="180dp"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_irrigation_card">
            <TextView
                android:id="@+id/seg_repeat_on"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="매주 반복"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/moss"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:focusable="true" />
            <TextView
                android:id="@+id/seg_repeat_off"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="단건"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/bg_btn_zone_start"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>
    </LinearLayout>

    <!-- ══ 요일 선택 박스 (반복 ON일 때만 VISIBLE) ══
         초기값: 7개 모두 ON (= 매일 반복). 사용자가 빼고 싶은 요일을 OFF로 토글.
         7개 모두 선택 → isRepeat=1, 일부 선택 → isRepeat=2(주간반복).
         0개 선택 시: 등록 차단 + "선택된 요일이 없습니다" 표시 -->
    <LinearLayout
        android:id="@+id/add_row_weekdays"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_irrigation_card"
        android:padding="12dp"
        android:layout_marginBottom="12dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="반복할 요일 · 전체 선택 시 매일 반복"
            android:textColor="@color/mist"
            android:textSize="12sp"
            android:layout_marginBottom="8dp" />

        <!-- 요일 칩 7개 — 가로 균등 분할 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">
            <TextView android:id="@+id/chip_mon"
                android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:gravity="center" android:text="월"
                android:textSize="13sp" android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/bg_btn_zone_start"
                android:clickable="true" android:focusable="true" />
            <TextView android:id="@+id/chip_tue"
                android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:gravity="center" android:text="화"
                android:textSize="13sp" android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/bg_btn_zone_start"
                android:clickable="true" android:focusable="true" />
            <TextView android:id="@+id/chip_wed"
                android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:gravity="center" android:text="수"
                android:textSize="13sp" android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/bg_btn_zone_start"
                android:clickable="true" android:focusable="true" />
            <TextView android:id="@+id/chip_thu"
                android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:gravity="center" android:text="목"
                android:textSize="13sp" android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/bg_btn_zone_start"
                android:clickable="true" android:focusable="true" />
            <TextView android:id="@+id/chip_fri"
                android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:gravity="center" android:text="금"
                android:textSize="13sp" android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/bg_btn_zone_start"
                android:clickable="true" android:focusable="true" />
            <TextView android:id="@+id/chip_sat"
                android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:gravity="center" android:text="토"
                android:textSize="13sp" android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/bg_btn_zone_start"
                android:clickable="true" android:focusable="true" />
            <TextView android:id="@+id/chip_sun"
                android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"
                android:gravity="center" android:text="일"
                android:textSize="13sp" android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/bg_btn_zone_start"
                android:clickable="true" android:focusable="true" />
        </LinearLayout>

        <!-- 선택 요약 (전체=매일반복 / 일부=요일 나열 / 0개=경고) -->
        <TextView
            android:id="@+id/tv_weekday_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="매일 반복"
            android:textColor="@color/gold"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="end" />
    </LinearLayout>

    <!-- 날짜 (반복 시 GONE, 단건 시 VISIBLE) -->
    <LinearLayout
        android:id="@+id/add_row_date"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">
        <TextView android:layout_width="80dp" android:layout_height="wrap_content"
            android:text="날짜" android:textColor="@color/mist" android:textSize="16sp" />
        <LinearLayout
            android:id="@+id/add_btn_date"
            android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:background="@drawable/bg_input_normal"
            android:clickable="true" android:focusable="true"
            android:paddingStart="14dp" android:paddingEnd="12dp">
            <TextView
                android:id="@+id/add_txt_date"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="날짜 선택"
                android:textColor="@color/text_hint" android:textSize="17sp" />
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@android:drawable/ic_menu_today"
                android:alpha="0.5" />
        </LinearLayout>
    </LinearLayout>

    <!-- 시작 시간 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:layout_marginBottom="12dp">
        <TextView android:layout_width="80dp" android:layout_height="wrap_content"
            android:text="시작 시간" android:textColor="@color/mist" android:textSize="16sp" />
        <LinearLayout android:id="@+id/add_btn_start_time"
            android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:background="@drawable/bg_input_normal"
            android:clickable="true" android:focusable="true"
            android:paddingStart="14dp" android:paddingEnd="12dp">
            <TextView android:id="@+id/add_txt_start_time"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="시작 시간 선택"
                android:textColor="@color/text_hint" android:textSize="17sp" />
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@android:drawable/ic_menu_recent_history"
                android:alpha="0.5" />
        </LinearLayout>
    </LinearLayout>

    <!-- 메인함 선택 (공통) -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:layout_marginBottom="16dp">
        <TextView android:layout_width="80dp" android:layout_height="wrap_content"
            android:text="메인함" android:textColor="@color/mist" android:textSize="16sp" />
        <LinearLayout android:id="@+id/add_btn_zone"
            android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:background="@drawable/bg_input_normal"
            android:clickable="true" android:focusable="true"
            android:paddingStart="14dp" android:paddingEnd="12dp">
            <TextView android:id="@+id/add_txt_zone"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="메인함 선택  ▼"
                android:textColor="@color/text_hint" android:textSize="17sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- 탭: 자동관수 / 개별관수 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_irrigation_card"
        android:layout_marginBottom="12dp">
        <TextView android:id="@+id/add_tab_type"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center"
            android:text="자동 관수" android:textSize="15sp" android:textStyle="bold"
            android:textColor="@color/white"
            android:background="@drawable/bg_btn_zone_start"
            android:clickable="true" android:focusable="true" />
        <TextView android:id="@+id/add_tab_direct"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center"
            android:text="개별 관수" android:textSize="15sp" android:textStyle="bold"
            android:textColor="@color/moss"
            android:background="@android:color/transparent"
            android:clickable="true" android:focusable="true" />
    </LinearLayout>

    <!-- ══ 패널 A: 자동관수 — 선택된 유형 표시 ══ -->
    <LinearLayout android:id="@+id/add_panel_list"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_irrigation_card"
        android:padding="14dp" android:layout_marginBottom="8dp"
        android:visibility="gone">

        <!-- 선택된 유형 정보 행 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <!-- 유형명 + 패턴 정보 -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:id="@+id/add_selected_type_name"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="유형 미선택"
                    android:textSize="17sp" android:textStyle="bold"
                    android:textColor="@color/text_hint" />
                <LinearLayout android:id="@+id/add_selected_type_info"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginTop="4dp"
                    android:visibility="gone">
                    <TextView android:id="@+id/add_selected_type_run"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="13sp" android:textColor="@color/text_secondary" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="  ·  " android:textSize="13sp" android:textColor="@color/text_hint" />
                    <TextView android:id="@+id/add_selected_type_rest"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="13sp" android:textColor="@color/text_secondary" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="  ·  " android:textSize="13sp" android:textColor="@color/text_hint" />
                    <TextView android:id="@+id/add_selected_type_repeat"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="13sp" android:textColor="@color/text_secondary" />
                </LinearLayout>
            </LinearLayout>

            <!-- 변경 버튼 -->
            <TextView android:id="@+id/add_btn_change_type"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="유형 선택"
                android:textSize="14sp" android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/bg_btn_zone_start"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:paddingTop="8dp" android:paddingBottom="8dp"
                android:clickable="true" android:focusable="true" />
        </LinearLayout>

        <!-- 구분선 -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/divider" android:layout_marginBottom="12dp" />

        <!-- 실행 방식 (isSeq) -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="실행 방식" android:textSize="13sp"
            android:textColor="@color/text_hint" android:layout_marginBottom="6dp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_irrigation_card">
            <TextView android:id="@+id/add_adjust_seq_sim"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:gravity="center"
                android:text="동시 실행" android:textSize="15sp" android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/bg_btn_zone_start"
                android:clickable="true" android:focusable="true" />
            <TextView android:id="@+id/add_adjust_seq_ord"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:gravity="center"
                android:text="순차 실행" android:textSize="15sp" android:textStyle="bold"
                android:textColor="@color/moss"
                android:background="@android:color/transparent"
                android:clickable="true" android:focusable="true" />
        </LinearLayout>

        <!-- 호환용 숨김 -->
        <LinearLayout android:id="@+id/add_type_card_container" android:layout_width="0dp"
            android:layout_height="0dp" android:visibility="gone" />
        <LinearLayout android:id="@+id/add_card_no_type" android:layout_width="0dp"
            android:layout_height="0dp" android:visibility="gone" />
        <TextView android:id="@+id/add_btn_add_type" android:layout_width="0dp"
            android:layout_height="0dp" android:visibility="gone" />
    </LinearLayout>

    <!-- ══ 패널 B: 개별관수 — 직접 입력 ══ -->
    <LinearLayout android:id="@+id/add_panel_direct"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_irrigation_card"
        android:padding="16dp" android:layout_marginBottom="8dp"
        android:visibility="gone">

        <!-- 가동시간 / 반복 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="가동 시간 (분)" android:textSize="13sp"
                    android:textColor="@color/text_hint" android:layout_marginBottom="4dp" />
                <EditText android:id="@+id/add_direct_run"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:text="30" android:textSize="20sp" android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:background="@drawable/bg_input_normal"
                    android:paddingStart="12dp" android:paddingEnd="12dp"
                    android:focusable="false" android:clickable="true"
                    android:singleLine="true" android:gravity="center" />
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="반복 횟수" android:textSize="13sp"
                    android:textColor="@color/text_hint" android:layout_marginBottom="4dp" />
                <EditText android:id="@+id/add_direct_repeat"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:text="1" android:textSize="20sp" android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:background="@drawable/bg_input_normal"
                    android:paddingStart="12dp" android:paddingEnd="12dp"
                    android:inputType="number" android:singleLine="true" android:gravity="center" />
            </LinearLayout>
        </LinearLayout>

        <!-- 휴지 시간 -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="휴지 시간 (분)" android:textSize="13sp"
            android:textColor="@color/text_hint" android:layout_marginBottom="4dp" />
        <EditText android:id="@+id/add_direct_rest"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:text="0" android:textSize="20sp" android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:background="@drawable/bg_input_normal"
            android:paddingStart="12dp" android:paddingEnd="12dp"
            android:focusable="false" android:clickable="true"
            android:singleLine="true" android:gravity="center"
            android:layout_marginBottom="12dp" />

        <!-- 밸브 선택 -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="밸브 선택" android:textSize="13sp"
            android:textColor="@color/text_hint" android:layout_marginBottom="6dp" />
        <TextView android:id="@+id/add_direct_device_btn"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:gravity="center_vertical"
            android:text="밸브 선택  ▼"
            android:textSize="15sp" android:textColor="@color/text_hint"
            android:background="@drawable/bg_input_normal"
            android:paddingStart="14dp" android:paddingEnd="14dp"
            android:layout_marginBottom="6dp"
            android:clickable="true" android:focusable="true" />

        <!-- 선택된 밸브 태그 -->
        <HorizontalScrollView
            android:id="@+id/add_direct_tags_scroll"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:scrollbars="none" android:layout_marginBottom="12dp"
            android:visibility="gone">
            <LinearLayout android:id="@+id/add_direct_device_tags"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal" android:paddingEnd="8dp" />
        </HorizontalScrollView>

        <!-- 실행 방식 (isSeq) — 개별관수 -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="실행 방식" android:textSize="13sp"
            android:textColor="@color/text_hint" android:layout_marginBottom="6dp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_irrigation_card">
            <TextView android:id="@+id/add_direct_seq_sim"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:gravity="center"
                android:text="동시 실행" android:textSize="15sp" android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/bg_btn_zone_start"
                android:clickable="true" android:focusable="true" />
            <TextView android:id="@+id/add_direct_seq_ord"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:gravity="center"
                android:text="순차 실행" android:textSize="15sp" android:textStyle="bold"
                android:textColor="@color/moss"
                android:background="@android:color/transparent"
                android:clickable="true" android:focusable="true" />
        </LinearLayout>
    </LinearLayout>

    <!-- 호환용 숨김 뷰 (기존 코드 참조 유지) -->
    <LinearLayout android:id="@+id/add_panel_adjust" android:layout_width="0dp"
        android:layout_height="0dp" android:visibility="gone" />
    <LinearLayout android:id="@+id/add_panel_form" android:layout_width="0dp"
        android:layout_height="0dp" android:visibility="gone" />
    <LinearLayout android:id="@+id/add_selected_card_container" android:layout_width="0dp"
        android:layout_height="0dp" android:visibility="gone" />
    <LinearLayout android:id="@+id/add_btn_end_time" android:layout_width="0dp"
        android:layout_height="0dp" android:visibility="gone">
        <TextView android:id="@+id/add_txt_end_time" android:layout_width="0dp" android:layout_height="0dp" />
    </LinearLayout>
    <LinearLayout android:id="@+id/add_btn_device" android:layout_width="0dp"
        android:layout_height="0dp" android:visibility="gone">
        <TextView android:id="@+id/add_txt_device" android:layout_width="0dp" android:layout_height="0dp" />
    </LinearLayout>
    <TextView android:id="@+id/add_txt_irrigation_type" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <LinearLayout android:id="@+id/add_btn_irrigation_type" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
