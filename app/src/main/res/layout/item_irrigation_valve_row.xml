<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/card_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp">

        <!-- 상태 도트 -->
        <View
            android:id="@+id/dotValve"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/dot_shape"/>

        <!-- 밸브 정보 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvValveName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="토출 밸브 1"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="3dp">

                <TextView
                    android:id="@+id/tvValveZone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="A-01 구역"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/tvValveState"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="대기"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_badge_neutral"
                    android:textColor="#616161"/>
            </LinearLayout>
        </LinearLayout>

        <!-- 버튼 묶음 (상태에 따라 visible 전환) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- 시작 (대기 상태) -->
            <TextView
                android:id="@+id/btnValveStart"
                android:layout_width="64dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="▶"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/bg_btn_zone_start"
                android:visibility="visible"
                android:clickable="true"
                android:focusable="true"/>

            <!-- 일시정지 (관수중 상태) -->
            <TextView
                android:id="@+id/btnValvePause"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="⏸"
                android:textSize="16sp"
                android:textColor="#854F0B"
                android:background="@drawable/bg_badge_warn"
                android:layout_marginStart="4dp"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true"/>

            <!-- 재개 (일시정지 상태) -->
            <TextView
                android:id="@+id/btnValveResume"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="▶"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/bg_btn_zone_start"
                android:layout_marginStart="4dp"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true"/>

            <!-- 중지 (관수중 or 일시정지 상태) -->
            <TextView
                android:id="@+id/btnValveStop"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="■"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/device_accent_error"
                android:background="@drawable/bg_badge_neutral"
                android:layout_marginStart="4dp"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true"/>

            <!-- 처리중 스피너 (PENDING 상태에서만 표시) -->
            <ProgressBar
                android:id="@+id/spinnerValvePending"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:indeterminateTint="@color/device_accent_warn"
                android:visibility="gone"/>

        </LinearLayout>

    </LinearLayout>

    <!-- 행 구분선 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginStart="36dp"/>

</LinearLayout>