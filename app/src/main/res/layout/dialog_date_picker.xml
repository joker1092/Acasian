<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_white_card">

    <!-- 헤더 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/gradient_forest_header"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="20dp"
        android:paddingBottom="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="날짜 선택"
            android:textColor="@color/mist"
            android:textSize="15sp"
            android:layout_marginBottom="6dp"/>

        <!-- 선택된 날짜 미리보기 -->
        <TextView
            android:id="@+id/tvDatePreview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="날짜를 선택하세요"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- 월 이동 헤더 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/btnDatePrevMonth"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="◀"
            android:textSize="20sp"
            android:textColor="@color/moss"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"/>

        <TextView
            android:id="@+id/tvDateYearMonth"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="2025년 6월"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"/>

        <TextView
            android:id="@+id/btnDateNextMonth"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="▶"
            android:textSize="20sp"
            android:textColor="@color/moss"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"/>
    </LinearLayout>

    <!-- 요일 라벨 (한글) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingBottom="4dp">

        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:gravity="center"
            android:text="일" android:textSize="14sp" android:textColor="#E53935"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:gravity="center"
            android:text="월" android:textSize="14sp" android:textColor="@color/text_secondary"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:gravity="center"
            android:text="화" android:textSize="14sp" android:textColor="@color/text_secondary"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:gravity="center"
            android:text="수" android:textSize="14sp" android:textColor="@color/text_secondary"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:gravity="center"
            android:text="목" android:textSize="14sp" android:textColor="@color/text_secondary"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:gravity="center"
            android:text="금" android:textSize="14sp" android:textColor="@color/text_secondary"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:gravity="center"
            android:text="토" android:textSize="14sp" android:textColor="#1565C0"/>
    </LinearLayout>

    <!-- 날짜 그리드 -->
    <GridLayout
        android:id="@+id/gridDatePicker"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="7"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingBottom="8dp"/>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginStart="16dp" android:layout_marginEnd="16dp"/>

    <!-- 버튼 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="16dp">

        <Button
            android:id="@+id/btnDateCancel"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:text="취소"
            android:textSize="18sp"
            android:textColor="@color/text_hint"
            android:background="@null"
            android:paddingStart="20dp"
            android:paddingEnd="12dp"/>

        <Button
            android:id="@+id/btnDateConfirm"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:text="확인"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/moss"
            android:background="@null"
            android:paddingStart="12dp"
            android:paddingEnd="8dp"/>
    </LinearLayout>

</LinearLayout>
