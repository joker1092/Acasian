<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp"
    android:background="?attr/selectableItemBackground">

    <!-- 날짜/시간 컬럼 -->
    <LinearLayout
        android:layout_width="72dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginEnd="14dp">
        <TextView
            android:id="@+id/tvScheduleDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="06.01"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"/>
        <TextView
            android:id="@+id/tvScheduleTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="06:00"
            android:textColor="@color/moss"
            android:textSize="17sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <!-- 내용 컬럼 -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">
        <TextView
            android:id="@+id/tvScheduleName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="봄 아침 관수"
            android:textColor="@color/text_primary"
            android:textSize="17sp"
            android:textStyle="bold"/>
        <TextView
            android:id="@+id/tvScheduleTarget"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="컨트롤박스#1 전체"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <!-- 상태 배지 -->
    <TextView
        android:id="@+id/tvScheduleBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="예약"
        android:textSize="15sp"
        android:textStyle="bold"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:background="@drawable/bg_badge_ok"
        android:textColor="#1B5E20"/>
</LinearLayout>
