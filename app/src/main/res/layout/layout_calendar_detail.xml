<?xml version="1.0" encoding="utf-8"?>
<!--
    날짜 선택 시 하단에 표시되는 상세 패널.
    isPast() → 내역 버전 / 미래 → 예약 버전
    카드 클릭 → 상세 Dialog / FAB → 예약 추가 Dialog
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 스크롤 영역 -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/cal_background_color">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="120dp">

            <!-- 날짜 + 버전 라벨 행 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/txt_detail_date"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="3월 6일"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    android:textColor="@color/white" />

                <!-- 버전 뱃지: "내역" or "예약" -->
                <TextView
                    android:id="@+id/txt_detail_mode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="내역"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/mist"
                    android:background="@drawable/bg_acacia_tag"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp" />
            </LinearLayout>

            <!-- 카드 목록 (Java에서 동적 추가) -->
            <LinearLayout
                android:id="@+id/detail_card_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- 빈 상태 안내 -->
            <LinearLayout
                android:id="@+id/detail_empty_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="32dp"
                android:paddingBottom="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="등록된 작업이 없습니다"
                    android:textSize="19sp"
                    android:textColor="@color/mist" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- FAB: 예약 추가 (미래 날짜만 VISIBLE) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_work"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="96dp"
        android:src="@android:drawable/ic_input_add"
        android:contentDescription="작업 예약 추가"
        android:visibility="gone"
        app:backgroundTint="@color/moss"
        app:tint="@color/white"
        android:layout_gravity="bottom|end" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
