<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="?attr/cal_label_padding_v"
        android:paddingBottom="?attr/cal_label_padding_v">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/cal_sunday"
            android:textColor="?attr/cal_weekday_sun_color"
            android:textSize="?attr/cal_weekday_label_text_size"
            android:textStyle="bold" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/cal_monday"
            android:textColor="?attr/cal_weekday_default_color"
            android:textSize="?attr/cal_weekday_label_text_size" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/cal_tuesday"
            android:textColor="?attr/cal_weekday_default_color"
            android:textSize="?attr/cal_weekday_label_text_size" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/cal_wednesday"
            android:textColor="?attr/cal_weekday_default_color"
            android:textSize="?attr/cal_weekday_label_text_size" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/cal_thursday"
            android:textColor="?attr/cal_weekday_default_color"
            android:textSize="?attr/cal_weekday_label_text_size" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/cal_friday"
            android:textColor="?attr/cal_weekday_default_color"
            android:textSize="?attr/cal_weekday_label_text_size" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/cal_saturday"
            android:textColor="?attr/cal_weekday_sat_color"
            android:textSize="?attr/cal_weekday_label_text_size"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- 구분선 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#33FFFFFF"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp" />

</LinearLayout>
