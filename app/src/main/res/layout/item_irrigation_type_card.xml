<?xml version="1.0" encoding="utf-8"?>
<!-- 관수 유형 카드 아이템 (설정 탭 / 예약 다이얼로그 공용) -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_irrigation_card"
    android:padding="16dp"
    android:layout_marginBottom="10dp">

    <!-- 상단: 유형 이름 + 편집/삭제 버튼 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">

        <!-- 초록 원형 아이콘 -->
        <FrameLayout
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_avatar"
            android:layout_marginEnd="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="💧"
                android:textSize="16sp" />
        </FrameLayout>

        <!-- 이름 -->
        <TextView
            android:id="@+id/tvTypeName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="점적 관수"
            android:textSize="19sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <!-- 편집 버튼 -->
        <TextView
            android:id="@+id/btnEditType"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="✏"
            android:textSize="16sp"
            android:textColor="@color/moss"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true" />

        <!-- 삭제 버튼 -->
        <TextView
            android:id="@+id/btnDeleteType"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="✕"
            android:textSize="16sp"
            android:textColor="@color/device_accent_error"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- 구분선 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginBottom="10dp" />

    <!-- 하단: 설정값 3칸 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- 가동 시간 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tvRunMinutes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="30분"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/forest_dark" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="가동"
                android:textSize="14sp"
                android:textColor="@color/text_hint"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- 세로 구분선 -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/divider"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp" />

        <!-- 휴지 시간 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tvRestMinutes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10분"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="휴지"
                android:textSize="14sp"
                android:textColor="@color/text_hint"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- 세로 구분선 -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/divider"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp" />

        <!-- 반복 횟수 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tvRepeatCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2회"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="반복"
                android:textSize="14sp"
                android:textColor="@color/text_hint"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- 제어 대상 뱃지 -->
    <TextView
        android:id="@+id/tvTargetBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="전체"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#1B5E20"
        android:background="@drawable/bg_badge_ok"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:layout_marginTop="10dp" />

    <!-- 개별 노드 뱃지 목록 (ZONE_INDIVIDUAL 시만 표시) -->
    <LinearLayout
        android:id="@+id/tvNodeBadgeContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="6dp"
        android:visibility="gone" />

</LinearLayout>
