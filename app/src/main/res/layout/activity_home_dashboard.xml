<?xml version="1.0" encoding="utf-8"?>
<!--
    홈 대시보드 Activity 레이아웃
    구성: 헤더 / 상태카드 / 센서요약 / 큰버튼 4개 / 긴급중지
    탭 네비게이션 없음 — 모든 기능은 큰 버튼으로 진입
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/light_gray">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ── 헤더 ──────────────────────────────────────────────── -->
        <FrameLayout
            android:id="@+id/dashHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/gradient_forest_header">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvDashFarmName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvDashSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="스마트팜 IoT 제어"
                        android:textColor="@color/mist"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <!-- 알림 버튼 -->
                <FrameLayout
                    android:id="@+id/btnDashNotif"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_notif_btn">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_bell"
                        android:contentDescription="알림" />
                    <View
                        android:id="@+id/dashNotifBadge"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_gravity="top|end"
                        android:layout_margin="5dp"
                        android:background="@drawable/badge_red"
                        android:visibility="gone" />
                </FrameLayout>
            </LinearLayout>
        </FrameLayout>

        <!-- ── 본문 ──────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingBottom="24dp">

            <!-- ── 현재 상태 카드 ─────────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardDashStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/card_bg"
                xmlns:app="http://schemas.android.com/apk/res-auto">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- 상태 헤더 행 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <View
                            android:id="@+id/dashStatusDot"
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/dot_shape" />

                        <TextView
                            android:id="@+id/tvDashStatusLabel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="현재 상태"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp" />

                        <!-- 상태 배지 -->
                        <TextView
                            android:id="@+id/tvDashStatusBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="대기 중"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:background="@drawable/bg_badge_neutral"
                            android:textColor="@color/text_secondary" />
                    </LinearLayout>

                    <!-- 메인 상태 텍스트 -->
                    <TextView
                        android:id="@+id/tvDashStatusMain"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="관수 대기 중"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>

                    <!-- 서브 상태 (게이트웨이 / 남은시간) -->
                    <TextView
                        android:id="@+id/tvDashStatusSub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="다음 예약: 내일 06:00 봄 아침 관수"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:layout_marginBottom="10dp"/>

                    <!-- 진행 바 (관수 중일 때만 visible) -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:id="@+id/dashProgressDivider"
                        android:visibility="gone"/>

                    <LinearLayout
                        android:id="@+id/dashProgressRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="10dp"
                        android:visibility="gone">

                        <ProgressBar
                            android:id="@+id/dashProgressBar"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="0dp"
                            android:layout_height="8dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="10dp"
                            android:max="100"
                            android:progress="55"
                            android:progressTint="@color/moss"
                            android:progressBackgroundTint="@color/divider" />

                        <TextView
                            android:id="@+id/tvDashProgressTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="12분 남음"
                            android:textColor="@color/moss"
                            android:textSize="13sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <!-- 긴급 중지 버튼 — 관수 중일 때만 VISIBLE -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:id="@+id/dashEmergencyDivider"
                        android:layout_marginTop="12dp"
                        android:visibility="gone"/>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnDashEmergencyStop"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:layout_marginTop="12dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/device_bg_error"
                        android:visibility="gone"
                        xmlns:app="http://schemas.android.com/apk/res-auto">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="horizontal">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="■  긴급 중지"
                                android:textColor="@color/device_accent_error"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.04"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── 센서 요약 카드 ────────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardDashSensor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/card_bg"
                xmlns:app="http://schemas.android.com/apk/res-auto">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="센서 현황"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:layout_marginBottom="6dp"/>

                    <!-- 센서 4칸 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- 지습 -->
                        <LinearLayout
                            android:id="@+id/sensorCellSoil"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/bg_white_card"
                            android:padding="7dp"
                            android:layout_marginEnd="6dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="지습"
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp"/>
                            <TextView
                                android:id="@+id/tvSensorSoil"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="32%"
                                android:textColor="@color/text_primary"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:layout_marginTop="1dp"/>
                        </LinearLayout>

                        <!-- 지온 -->
                        <LinearLayout
                            android:id="@+id/sensorCellTemp"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/bg_white_card"
                            android:padding="7dp"
                            android:layout_marginEnd="6dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="지온"
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp"/>
                            <TextView
                                android:id="@+id/tvSensorTemp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="21°C"
                                android:textColor="@color/text_primary"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:layout_marginTop="1dp"/>
                        </LinearLayout>

                        <!-- EC -->
                        <LinearLayout
                            android:id="@+id/sensorCellEC"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/bg_white_card"
                            android:padding="7dp"
                            android:layout_marginEnd="6dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="EC"
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp"/>
                            <TextView
                                android:id="@+id/tvSensorEC"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="1.8"
                                android:textColor="@color/text_primary"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:layout_marginTop="1dp"/>
                        </LinearLayout>

                        <!-- pH -->
                        <LinearLayout
                            android:id="@+id/sensorCellPH"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/bg_white_card"
                            android:padding="7dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="pH"
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp"/>
                            <TextView
                                android:id="@+id/tvSensorPH"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="6.5"
                                android:textColor="@color/text_primary"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:layout_marginTop="1dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── 알림 카드 (있을 때만 표시) ─────────────────────── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardDashAlert"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFF8E1"
                android:visibility="gone"
                xmlns:app="http://schemas.android.com/apk/res-auto">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:id="@+id/tvDashAlertMsg"
                        android:text="⚠ 구역 3 습도 낮음 (08:42)"
                        android:textColor="@color/soil"
                        android:textSize="13sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="확인 →"
                        android:textColor="@color/bark"
                        android:textSize="13sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── 큰 버튼 섹션 라벨 ──────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="빠른 메뉴"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="2dp"/>

            <!-- ── 큰 버튼 2x2 그리드 ─────────────────────────────── -->
            <!-- 행 1: 관수작업 / 예약설정 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <!-- 관수작업 버튼 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/btnDashIrrigation"
                    android:layout_width="0dp"
                    android:layout_height="88dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/morning"
                    xmlns:app="http://schemas.android.com/apk/res-auto">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_pump"
                            android:layout_marginBottom="6dp"
                            android:contentDescription="관수작업" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="관수작업"
                            android:textColor="@color/forest_dark"
                            android:textSize="15sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tvDashIrrigationSub"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="밸브 제어"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- 예약설정 버튼 (노란 강조) -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/btnDashSchedule"
                    android:layout_width="0dp"
                    android:layout_height="88dp"
                    android:layout_weight="1"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#FFF8E1"
                    xmlns:app="http://schemas.android.com/apk/res-auto">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_sun"
                            android:layout_marginBottom="6dp"
                            android:contentDescription="예약설정" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="예약설정"
                            android:textColor="@color/soil"
                            android:textSize="15sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tvDashScheduleSub"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="스케줄 관리"
                            android:textColor="@color/bark"
                            android:textSize="13sp"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- 행 2: 정보조회 / 설정 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <!-- 정보조회 버튼 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/btnDashInfo"
                    android:layout_width="0dp"
                    android:layout_height="88dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#E0F2F1"
                    xmlns:app="http://schemas.android.com/apk/res-auto">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_sensor"
                            android:layout_marginBottom="6dp"
                            android:contentDescription="정보조회" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="정보조회"
                            android:textColor="#004D40"
                            android:textSize="15sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="센서 데이터"
                            android:textColor="#00695C"
                            android:textSize="13sp"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- 설정 버튼 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/btnDashSettings"
                    android:layout_width="0dp"
                    android:layout_height="88dp"
                    android:layout_weight="1"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/inactive_bg"
                    xmlns:app="http://schemas.android.com/apk/res-auto">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_nav_settings"
                            android:layout_marginBottom="6dp"
                            android:contentDescription="설정" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="설정"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="유형 · 환경기준"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>





        </LinearLayout>
    </LinearLayout>
</LinearLayout>
